# Root directory where all project data will be stored.
# This should point to the base folder containing bronze/, silver/, and gold/ layers.
# Example (Windows): G:\data\energy-price-analyst
# Example (Mac/Linux): /Users/yourname/data/energy-price-analyst
DATA_ROOT=

# AI provider used for natural language → SQL generation.
# Supported values:
#   ollama   → Uses a locally running LLaMA model via Ollama (default and recommended)
# Future options may include:
#   openai   → Cloud-based models (not yet implemented)
AI_PROVIDER=